{
  "name": "openclaw-a2a",
  "displayName": "OpenClaw A2A - Agent-to-Agent Communication",
  "description": "Cross-machine agent communication for VS Code Server",
  "version": "0.1.0",
  "publisher": "openclaw",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Debuggers"
  ],
  "keywords": [
    "a2a",
    "agent",
    "openclaw",
    "remote",
    "distributed"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openclaw-a2a.discover",
        "title": "Discover Remote Agents",
        "category": "OpenClaw A2A",
        "icon": "$(search)"
      },
      {
        "command": "openclaw-a2a.sendMessage",
        "title": "Send Message to Agent",
        "category": "OpenClaw A2A",
        "icon": "$(comment)"
      },
      {
        "command": "openclaw-a2a.delegateTask",
        "title": "Delegate Task to Remote Agent",
        "category": "OpenClaw A2A",
        "icon": "$(run)"
      },
      {
        "command": "openclaw-a2a.startServer",
        "title": "Start A2A Server",
        "category": "OpenClaw A2A",
        "icon": "$(server)"
      },
      {
        "command": "openclaw-a2a.stopServer",
        "title": "Stop A2A Server",
        "category": "OpenClaw A2A",
        "icon": "$(debug-stop)"
      },
      {
        "command": "openclaw-a2a.showPanel",
        "title": "Show A2A Panel",
        "category": "OpenClaw A2A",
        "icon": "$(broadcast)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "openclaw-a2a.agents",
          "name": "Remote Agents",
          "when": "openclaw-a2a.enabled"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openclaw-a2a",
          "title": "OpenClaw A2A",
          "icon": "$(broadcast)"
        }
      ]
    },
    "configuration": {
      "title": "OpenClaw A2A",
      "properties": {
        "openclaw-a2a.server.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable A2A server on this machine"
        },
        "openclaw-a2a.server.port": {
          "type": "number",
          "default": 8080,
          "description": "Port for A2A server"
        },
        "openclaw-a2a.server.token": {
          "type": "string",
          "default": "",
          "description": "Authentication token for A2A server"
        },
        "openclaw-a2a.agents": {
          "type": "array",
          "default": [],
          "description": "List of remote agents",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "token": {
                "type": "string"
              }
            }
          }
        },
        "openclaw-a2a.capabilities": {
          "type": "array",
          "default": [
            "file_operation",
            "terminal",
            "docker"
          ],
          "description": "Capabilities this agent provides"
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "openclaw-a2a.discover",
          "when": "openclaw-a2a.enabled"
        },
        {
          "command": "openclaw-a2a.delegateTask",
          "when": "openclaw-a2a.enabled"
        }
      ],
      "view/title": [
        {
          "command": "openclaw-a2a.discover",
          "when": "view == openclaw-a2a.agents",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "openclaw-a2a.showPanel",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "typescript": "^4.9.4",
    "@vscode/test-electron": "^2.2.0",
    "@vscode/vsce": "^2.15.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "ws": "^8.14.0",
    "@types/ws": "^8.5.0"
  }
}
